{
  "manifestVersion": 5,
  "id": "com.mcdiva.mark.premiere",
  "name": "Mark",
  "version": "0.1.0",
  "main": "src/index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "markPanel",
      "label": {
        "default": "Mark"
      },
      "minimumSize": {
        "width": 720,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 980,
        "height": 720
      }
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "static/application.svg",
      "theme": [
        "all"
      ],
      "scale": [
        1,
        2
      ]
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "localhost",
        "127.0.0.1"
      ]
    }
  }
}
